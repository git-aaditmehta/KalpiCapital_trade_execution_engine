# Application settings
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000

# Webhook URL for notifications (mock)
WEBHOOK_URL=http://localhost:8000/webhook/mock

# ─── Zerodha (Kite Connect) ───
# Portal: https://developers.kite.trade
# Steps: Create app → Get api_key & api_secret → Login via Kite → Get access_token
ZERODHA_API_KEY=
ZERODHA_API_SECRET=
ZERODHA_ACCESS_TOKEN=

# ─── Fyers ───
# Portal: https://myapi.fyers.in/dashboard
# Steps: Create app → Get app_id & secret_key → OAuth login → Get access_token
FYERS_APP_ID=
FYERS_SECRET_KEY=
FYERS_ACCESS_TOKEN=

# ─── Angel One (SmartAPI) ───
# Portal: https://smartapi.angelone.in/
# Steps: Create app → Get api_key → Use client_id + password + TOTP to login
ANGELONE_API_KEY=
ANGELONE_CLIENT_ID=
ANGELONE_PASSWORD=
ANGELONE_TOTP_SECRET=

# ─── Groww ───
# NOTE: Groww does NOT have a public trading API. This adapter uses mock data.
# If Groww releases a public API in the future, fill these fields.
GROWW_API_KEY=
GROWW_API_SECRET=

# ─── Upstox ───
# Portal: https://account.upstox.com/developer/apps
# Steps: Create app → Get api_key & api_secret → OAuth login → Get access_token
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_ACCESS_TOKEN=
UPSTOX_REDIRECT_URI=http://localhost:3000/callback

# ─── Dhan ───
# Portal: https://api.dhan.co
# Steps: Login → Create app → Get client_id → Generate access_token
DHAN_CLIENT_ID=
DHAN_ACCESS_TOKEN=
